# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Railway: PORT is injected automatically, do not set it.
# Set CLIENT_URL to your frontend URL (e.g. https://your-app.vercel.app)

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/talenthire


# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
